# ── Ants backend environment ────────────────────────────────────────────────
# Copy to .env (or set in Railway/Render dashboard). Everything is optional —
# the app runs without any of these, with AI features in fallback mode.

# Enables AI: screenshot OCR, punched-up analysis copy, Ask Ants chat.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model for all AI calls (default: claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5

# Comma-separated frontend origins allowed by CORS.
# Add your deployed frontend, e.g. https://ants.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Set by Railway/Render automatically; local default 8000.
PORT=8000
